{
  "name": "layla-server",
  "version": "2.0.0",
  "main": "dist/main.js",
  "author": "Layla Network Pty Ltd",
  "description": "Layla server powered by LocalAI, proxying WebRTC to OpenAI specs.",
  "scripts": {
    "setup": "node scripts/setup-env.js",
    "build": "tsc && esbuild src/renderer.tsx --bundle --outfile=public/renderer.js --platform=browser",
    "start": "npm run build && electron .",
    "make:installer": "npm run build && electron-forge make --targets @electron-forge/maker-squirrel",
    "make:portable": "npm run build && electron-forge make --targets @electron-forge/maker-zip"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^30.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "js-yaml": "^4.1.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
